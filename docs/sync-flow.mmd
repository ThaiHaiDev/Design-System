        CACHE[".cloud-manifest-cache.json"]
        MANIFEST["_ds_manifest.json local"]
        SPEC["spec.json"]
        HTML["Login.dc.html local"]
        TOKENMAP["token-values.json"]
        LOG["sync-login.log"]
    end

    subgraph SCRIPTS["Scripts"]
        DIFF["design-diff.mjs"]
        GENTEST["gen-login-tests.mjs"]
