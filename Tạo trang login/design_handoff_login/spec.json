{
  "version": 1,
  "page": "login",
  "layout": {
    "container": {
      "minHeight": "100vh",
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "center",
      "background": "--bg-primary"
    },
    "card": {
      "width": 360,
      "background": "--bg-secondary",
      "border": "1px --border-default",
      "borderRadius": "--radius-xl",
      "shadow": "--shadow-sm",
      "padding": "--space-8"
    }
  },
  "components": {
    "header": {
      "container": {
        "display": "flex",
        "flexDirection": "column",
        "alignItems": "center",
        "textAlign": "center",
        "marginBottom": "--space-6"
      },
      "logoMark": {
        "width": 40,
        "height": 40,
        "borderRadius": "--radius-md",
        "background": "--accent-primary",
        "letter": "V",
        "fontFamily": "--font-display",
        "fontSize": "--text-lg",
        "fontWeight": "--weight-extrabold",
        "color": "--text-inverse",
        "marginBottom": "--space-3"
      }
    },
    "wordmark": {
      "text": "Verity",
      "fontFamily": "--font-display",
      "fontSize": "--text-3xl",
      "fontWeight": "--weight-extrabold",
      "letterSpacing": "-0.02em",
      "lineHeight": "--leading-3xl",
      "color": "--text-primary"
    },
    "subtitle": {
      "text": "Sign in to your account",
      "fontSize": "--text-sm",
      "color": "--text-secondary",
      "marginTop": "4px"
    },
    "socialButtons": {
      "items": ["Continue with Google", "Continue with GitHub"],
      "variant": "secondary",
      "size": "lg",
      "height": 44,
      "fullWidth": true,
      "gap": "--space-3",
      "marginBottom": "--space-6",
      "background": "transparent",
      "border": "1px --border-default",
      "color": "--text-primary",
      "icon": {
        "size": 18,
        "gap": "--space-2",
        "google": "brand-colored multi-path SVG (blue/green/yellow/red)",
        "github": "single-path SVG, currentColor"
      }
    },
    "divider": {
      "label": "OR",
      "labelFontSize": "--text-xs",
      "labelColor": "--text-tertiary",
      "lineColor": "--border-default",
      "gap": "--space-3",
      "marginBottom": "--space-6"
    },
    "form": {
      "emailInput": {
        "label": "Email",
        "type": "email",
        "placeholder": "you@company.com",
        "size": "lg"
      },
      "passwordInput": {
        "label": "Password",
        "type": "password",
        "size": "lg",
        "visibilityToggle": {
          "ariaLabel": "Toggle password visibility",
          "iconSize": 18,
          "iconColor": "--text-tertiary",
          "position": "inset-right"
        }
      },
      "inputGap": "--space-4",
      "rememberMe": {
        "label": "Remember me",
        "defaultChecked": true
      },
      "forgotPassword": {
        "text": "Forgot password?",
        "fontSize": "--text-sm",
        "color": "--accent-primary"
      }
    },
    "signInButton": {
      "text": "Sign in",
      "variant": "primary",
      "size": "lg",
      "height": 44,
      "fullWidth": true,
      "background": "--accent-primary",
      "color": "--text-inverse"
    },
    "signUpRow": {
      "text": "Don't have an account?",
      "linkText": "Sign up",
      "fontSize": "--text-sm",
      "color": "--text-secondary",
      "linkColor": "--accent-primary",
      "linkWeight": "--weight-medium",
      "marginTop": "--space-6",
      "textAlign": "center"
    }
  }
}
